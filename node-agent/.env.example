# node-exporter :9100 is exposed on all host interfaces via network_mode: host.
# Restrict access via host firewall rules to central Prometheus IP only.

# Порт, на котором caddy-metrics отдаёт метрики наружу (TLS + basic auth)
METRICS_PORT=8443

# Basic auth. Хеш сгенерить: ./scripts/gen-htpasswd.sh <user> <password>
# ВАЖНО: в хеше каждый '$' удвоен до '$$' — иначе docker compose интерполирует
# его как переменную и хеш побьётся (Caddy отдаст 401). gen-htpasswd.sh уже
# печатает готовый экранированный вариант — вставляй как есть.
METRICS_USER=metrics
METRICS_PASSWORD_HASH=$$2a$$14$$REPLACE_WITH_ESCAPED_BCRYPT_HASH

# gRPC Stats API xray-ядра панели. Подтверждено по compose панели:
# сервис "xray" (container_name xray-core) слушает API на :10085,
# его дёргают backend и встроенный metrics-агент, т.е. слушает на сети (не localhost).
XRAY_API_ENDPOINT=xray:10085

# Внешняя docker-сеть панели, к которой цепляется xray-exporter, чтобы достучаться
# до XRAY_API_ENDPOINT. У панели для этого есть выделенная internal-сеть metrics-xray-net
# (в ней сидит xray). Имя префиксится проектом compose — уточнить на ноде:
#   docker network ls | grep metrics-xray
# Обычно это <project>_metrics-xray-net, напр.:
PANEL_NETWORK=itg_xray_panel_metrics-xray-net
