# bcrypt-хеш пароля basic-auth для caddy-metrics.
# Сгенерить: ./scripts/gen-htpasswd.sh <user> <password>
# Пароль тут — плейнтекстом на central (METRICS_PASSWORD), хеш — тут.
# Этот файл НЕ автоподхватывается docker compose (только через env_file),
# поэтому '$' в хеше не интерполируется и доходит до Caddy без искажений.
METRICS_PASSWORD_HASH=$2a$14$REPLACE_WITH_BCRYPT_HASH
